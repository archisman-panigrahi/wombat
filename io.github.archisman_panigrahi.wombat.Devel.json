{
  "app-id": "io.github.archisman_panigrahi.wombat",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "wombat",
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/wombat/cargo",
      "RUSTUP_HOME": "/run/build/wombat/rustup"
    }
  },
  "finish-args": [
    "--share=network",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "modules": [
    {
      "name": "wombat",
      "buildsystem": "simple",
      "build-commands": [
        "cargo build --release --locked",
        "install -Dm755 target/release/wombat /app/bin/wombat",
        "install -Dm644 data/io.github.archisman_panigrahi.wombat.desktop /app/share/applications/io.github.archisman_panigrahi.wombat.desktop",
        "install -Dm644 data/io.github.archisman_panigrahi.wombat.metainfo.xml /app/share/metainfo/io.github.archisman_panigrahi.wombat.metainfo.xml",
        "install -Dm644 data/io.github.archisman_panigrahi.wombat.svg /app/share/icons/hicolor/scalable/apps/io.github.archisman_panigrahi.wombat.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
