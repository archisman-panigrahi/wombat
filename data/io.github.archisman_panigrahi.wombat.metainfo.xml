<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.archisman_panigrahi.wombat</id>
  <name>Wombat</name>
  <summary>High-precision scientific calculator with full unit support, powered by Numbat</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="io.github.archisman-panigrahi">
    <name>Archisman Panigrahi</name>
  </developer>

  <description>
    <p>
      Wombat gives Numbat a friendly face: a high-precision graphical calculator built for scientists and engineers.
      Designed for unit-aware scientific computing, conversions just work—no need to juggle factors or second-guess results.
      Type expressions naturally, mix units freely, and let Wombat keep your calculations consistent, your units correct, and your workflow smooth.
    </p>
  </description>

  <launchable type="desktop-id">io.github.archisman_panigrahi.wombat.desktop</launchable>

  <provides>
    <binary>wombat</binary>
  </provides>

  <url type="homepage">https://archisman-panigrahi.github.io/wombat/</url>
  <url type="vcs-browser">https://github.com/archisman-panigrahi/wombat</url>

  <releases>
